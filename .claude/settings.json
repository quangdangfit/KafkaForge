{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(go *)",
      "Bash(golangci-lint run ./...)",
      "Bash(make *)",
      "Bash(docker-compose *)",
      "Bash(docker *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(git *)",
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "LS"
    ],
    "deny": [
      "Read(.env*)",
      "Read(*secret*)",
      "Read(*credential*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(docker rm *)",
      "Bash(docker rmi *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)"
    ]
  },
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "30000",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-7",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6"
  }
}
